# =============================================================================
#  Studio screen-mgr secrets + per-deploy hostnames
# =============================================================================
#
# Copy to .env on the production Pi:
#     cp .env.example .env && nano .env && chmod 600 .env
#
# .env is gitignored — NEVER commit a real key.
# Code reads each var at runtime via os.environ + python-dotenv (loaded in
# agents/__init__.py). Missing values degrade with a clear error rather
# than crashing the server.

# -----------------------------------------------------------------------------
#  Agents (Anthropic) — PLAN_AGENTIC.md Phases 2+
# -----------------------------------------------------------------------------
# Required to run the Lighting specialist + Studio orchestrator + the real
# /api/chat backend. Get one at https://console.anthropic.com .
ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional: override the MCP server base URL (defaults to localhost:8000).
# Useful when running an agent CLI from a dev machine pointed at the Pi.
# SCREEN_MGR_MCP_BASE=http://studiopi:8000

# -----------------------------------------------------------------------------
#  Music — Spotify Web API (Path B; Path A = embedded player only)
# -----------------------------------------------------------------------------
# One-time OAuth setup: see docs/DEPLOY.md → "Spotify setup".
# Without these, the Music MCP tools return {"error": "spotify not configured"}.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
#  Music — Marantz Cinema 70s via HEOS (drives the Bose speakers)
# -----------------------------------------------------------------------------
# Single point-to-point TCP target for HEOS control + local-file playback.
# We never broadcast / scan for it; only ever talk to this exact host:port.
# MARANTZ_HEOS_HOST=192.168.2.163
# MARANTZ_HEOS_PORT=1255

# -----------------------------------------------------------------------------
#  Audio — Sennheiser TeamConnect Ceiling Medium mic (SSCv2 API)
# -----------------------------------------------------------------------------
# Username defaults to 'api' (matches the SSCv2 "ssc" realm).
# Password is set during commissioning in Sennheiser Control Cockpit under:
#   Devices > {device} > Access > 3rd Party Access > Edit > Secure
# Without the password we still get mic discovery + identity/identification
# reads + reachability probe; with it, mute / LED-flash / full state unlock.
# SENNHEISER_TCC_USERNAME=api
# SENNHEISER_TCC_PASSWORD=
#
# Optional: pin the TCC by host instead of relying on mDNS discovery.
# Useful when the studio's TCC has a stable IP and you want to skip the
# avahi-browse step entirely.
# SENNHEISER_TCC_HOST=192.168.2.220

# -----------------------------------------------------------------------------
#  Safety — acoustic-feedback prevention (docs/SAFETY.md)
# -----------------------------------------------------------------------------
# Hard ceiling clamped onto every speaker-write code path. The default is
# 70 (cap any volume above 70 %). Raise ONLY after reading docs/SAFETY.md
# and considering the room's specific mic + speaker geometry.
# MAX_OUTPUT_VOLUME_PCT=70
