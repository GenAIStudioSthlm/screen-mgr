# Anthropic API key for the studio agents (Phase 2+ of TASKS/PLAN_AGENTIC.md).
#
# Copy this file to .env on the production Pi:
#     cp .env.example .env && nano .env
# Then paste your real key from https://console.anthropic.com .
#
# .env is gitignored — NEVER commit a real key.
# If a real key accidentally lands in git, rotate it immediately at the console.

ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional: override the MCP server base URL (defaults to localhost:8000).
# Useful when running an agent CLI from a developer machine pointed at the Pi.
# SCREEN_MGR_MCP_BASE=http://studiopi:8000
